# Provider API Keys (only set the ones you need)
STABILITY_API_KEY=
REPLICATE_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
DEEPGRAM_API_KEY=
FAL_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Storage Configuration
STORAGE_TYPE=local
STORAGE_PATH=./artifacts
STORAGE_TTL=86400
STORAGE_SERVE_HTTP=false
# For S3:
S3_BUCKET=
S3_REGION=us-east-1
S3_PREFIX=artifacts/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# For GCS:
GCS_BUCKET=
GCS_PREFIX=artifacts/
GOOGLE_APPLICATION_CREDENTIALS=

# Server Configuration
PORT=8080
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# MCP Server
MCP_TRANSPORT=streamable-http

# Authentication
AUTH_ENABLED=false
JWT_SECRET=
API_KEYS=

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=10
EXPENSIVE_OPS_RPM=10

# Cost Budgets (USD)
BUDGET_DAILY_LIMIT=100
BUDGET_MONTHLY_LIMIT=2000
BUDGET_PER_PIPELINE_LIMIT=
BUDGET_ALERT_THRESHOLD=0.9

# Observability (OpenTelemetry)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=media-pipeline-mcp
