    "@smithy/protocol-http": "^5.3.14",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@vitest/coverage-v8": "4.1.4",
    "vitest": "4.1.4"
