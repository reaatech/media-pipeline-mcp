{
  "name": "media-pipeline-mcp",
  "version": "0.1.0",
  "description": "Chainable media operations with quality gates as MCP tools",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r dev",
    "test": "pnpm -r run test",
    "test:coverage": "pnpm -r run test:coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,json}\"",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r clean && find packages -name 'tsconfig.tsbuildinfo' -delete",
    "sbom": "cyclonedx-npm --output-format JSON --output-file sbom.json",
    "prepare": "husky"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "^4.2.1",
    "@eslint/js": "^10.0.1",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@8.15.4",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/media-pipeline-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/reaatech/media-pipeline-mcp/issues"
  },
  "homepage": "https://github.com/reaatech/media-pipeline-mcp#readme",
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "uuid": "^9.0.1"
  },
  "overrides": {
    "protobufjs": ">=7.2.6"
  },
  "pnpm": {
    "overrides": {
      "protobufjs@>=7.0.0 <7.2.5": ">=7.2.5",
      "esbuild@<=0.24.2": ">=0.25.0",
      "@tootallnate/once@<3.0.1": ">=3.0.1",
      "vite@<=6.4.1": ">=6.4.2",
      "protobufjs@<7.5.5": ">=7.5.5"
    }
  }
}
