{
  "name": "@reaatech/media-pipeline-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Chainable media operations with quality gates as MCP tools",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 run build",
    "dev": "pnpm -r --workspace-concurrency=1 dev",
    "test": "pnpm -r --workspace-concurrency=1 run test",
    "test:coverage": "pnpm -r --workspace-concurrency=1 run test:coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r clean && find packages -name 'tsconfig.tsbuildinfo' -delete",
    "sbom": "cyclonedx-npm --output-format JSON --output-file sbom.json",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@cyclonedx/cyclonedx-npm": "^4.2.1",
    "@types/uuid": "^9.0.8",
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.22.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/media-pipeline-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/reaatech/media-pipeline-mcp/issues"
  },
  "homepage": "https://github.com/reaatech/media-pipeline-mcp#readme",
  "dependencies": {
    "uuid": "^9.0.1"
  },
  "overrides": {
    "protobufjs": ">=7.2.6"
  },
  "pnpm": {
    "overrides": {
      "protobufjs@>=7.0.0 <7.2.5": ">=7.2.5",
      "esbuild@<=0.24.2": ">=0.25.0",
      "@tootallnate/once@<3.0.1": ">=3.0.1",
      "vite@<=6.4.1": ">=6.4.2",
      "protobufjs@<7.5.5": ">=7.5.5"
    }
  }
}
